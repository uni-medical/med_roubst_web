---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="glass-strong border-t border-surface-200/50 mt-auto">
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center font-bold text-white text-lg">
            M
          </div>
          <span class="font-bold text-lg text-surface-900">MedQ-Deg</span>
        </div>
        <p class="text-surface-500 text-sm max-w-md">
          A multi-dimensional benchmark for medical image degradation recognition and beyond.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold mb-4 text-surface-800">Resources</h3>
        <ul class="space-y-2 text-sm text-surface-500">
          <li><a href="#" class="hover:text-primary-600 transition-colors">Paper</a></li>
          <li><a href="#" class="hover:text-primary-600 transition-colors">GitHub</a></li>
          <li><a href="#" class="hover:text-primary-600 transition-colors">Dataset</a></li>
          <li><a href="#" class="hover:text-primary-600 transition-colors">Documentation</a></li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold mb-4 text-surface-800">Explore</h3>
        <ul class="space-y-2 text-sm text-surface-500">
          <li><a href={`${base}/methods`} class="hover:text-primary-600 transition-colors">Benchmark</a></li>
          <li><a href={`${base}/results`} class="hover:text-primary-600 transition-colors">Results</a></li>
          <li><a href={`${base}/examples`} class="hover:text-primary-600 transition-colors">Examples</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-surface-200/50 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-surface-400">
      <p>&copy; {year} MedQ-Deg. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-surface-600 transition-colors">Privacy</a>
        <a href="#" class="hover:text-surface-600 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
