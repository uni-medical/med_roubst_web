---
const base = import.meta.env.BASE_URL;

const navItems = [
  { name: 'Home', href: base },
  { name: 'Benchmark', href: `${base}/benchmark` },
  { name: 'Methods', href: `${base}/methods` },
  { name: 'Results', href: `${base}/results` },
  { name: 'Examples', href: `${base}/examples` },
];

const currentPath = Astro.url.pathname;
// Normalize: strip trailing slash for comparison (except root)
const normPath = currentPath.endsWith('/') && currentPath !== base
  ? currentPath.slice(0, -1)
  : currentPath;
---

<header class="fixed top-0 left-0 right-0 z-50 glass-strong">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={base} class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center font-bold text-white text-lg group-hover:scale-110 transition-transform">
          M
        </div>
        <span class="font-bold text-lg hidden sm:inline text-surface-900">MedQ-Deg</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navItems.map((item) => {
          const normItem = item.href.endsWith('/') && item.href !== base
            ? item.href.slice(0, -1)
            : item.href;
          const isActive = normPath === normItem;
          return (
            <li>
              <a
                href={item.href}
                class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                  isActive
                    ? 'bg-primary-500/15 text-primary-600'
                    : 'text-surface-600 hover:text-surface-900 hover:bg-surface-100/70'
                }`}
              >
                {item.name}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary !px-4 !py-2 !text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="#" class="btn btn-primary !px-4 !py-2 !text-sm">
          Paper
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-surface-500 hover:text-surface-900 hover:bg-surface-100/70"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden glass-strong border-t border-surface-200/50"
  >
    <ul class="container-custom py-4 space-y-1">
      {navItems.map((item) => {
        const normItem = item.href.endsWith('/') && item.href !== base
          ? item.href.slice(0, -1)
          : item.href;
        const isActive = normPath === normItem;
        return (
          <li>
            <a
              href={item.href}
              class={`block px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                isActive
                  ? 'bg-primary-500/15 text-primary-600'
                  : 'text-surface-600 hover:text-surface-900 hover:bg-surface-100/70'
              }`}
            >
              {item.name}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
