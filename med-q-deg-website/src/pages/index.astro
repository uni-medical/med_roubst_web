---
import Layout from '@layouts/Layout.astro';
import { SITE_CONFIG, CATEGORIES, DEGRADATION_TYPES, CONTRIBUTIONS } from '@data/config';

const base = import.meta.env.BASE_URL;
---

<Layout title={SITE_CONFIG.title} description={SITE_CONFIG.description}>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary-50/50 via-surface-50 to-surface-50"></div>
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-400/15 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-400/15 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    </div>

    <div class="container-custom relative z-10 text-center">
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold mb-6 animate-on-scroll" style="animation-delay: 100ms;">
        <span class="gradient-text">MedQ-Deg</span>
      </h1>

      <p class="text-xl sm:text-2xl text-surface-500 max-w-3xl mx-auto mb-8 animate-on-scroll" style="animation-delay: 200ms;">
        {SITE_CONFIG.subtitle}
      </p>

      <!-- Stats -->
      <div class="flex flex-wrap justify-center gap-6 sm:gap-8 mb-12 animate-on-scroll" style="animation-delay: 300ms;">
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-bold text-primary-600">40</div>
          <div class="text-sm text-surface-500">MLLMs Evaluated</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-bold text-accent-600">24,894</div>
          <div class="text-sm text-surface-500">QA Pairs</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-bold text-primary-600">19</div>
          <div class="text-sm text-surface-500">Degradation Types</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-bold text-accent-600">30</div>
          <div class="text-sm text-surface-500">Fine-grained Skills</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-bold text-primary-600">7</div>
          <div class="text-sm text-surface-500">Modalities</div>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-wrap justify-center gap-4 animate-on-scroll" style="animation-delay: 400ms;">
        <a href={SITE_CONFIG.links.paper} class="btn btn-primary text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Read Paper
        </a>
        <a href={SITE_CONFIG.links.github} class="btn btn-secondary text-lg">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub
        </a>
        <a href={`${base}/examples`} class="btn btn-ghost text-lg">
          View Examples
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Framework Overview (Fig 2) -->
  <section class="section">
    <div class="container-custom">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Benchmark Framework</h2>
        <p class="text-surface-500 max-w-3xl mx-auto">
          Two orthogonal hierarchies structure the evaluation: a <strong>capability hierarchy</strong> decomposing clinical competence into 30 fine-grained skills, and a <strong>degradation hierarchy</strong> covering 19 degradation types across 7 modalities.
        </p>
      </div>
      <div class="animate-on-scroll">
        <div class="rounded-2xl overflow-hidden border border-surface-200 bg-white shadow-lg shadow-surface-200/50">
          <img src={`${base}/paper-figs/framework.png`} alt="MedQ-Deg Benchmark Framework" class="w-full" loading="lazy" />
        </div>
        <p class="text-center text-sm text-surface-400 mt-4">
          <strong>Fig. 2:</strong> Overview of the MedQ-Deg benchmark framework. Left: Medical MLLM Capability Hierarchy. Middle: Benchmark Construction pipeline. Right: Medical Image Degradation Hierarchy.
        </p>
      </div>
    </div>
  </section>

  <!-- Key Contributions -->
  <section class="section bg-surface-100/50">
    <div class="container-custom">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Key Contributions</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {CONTRIBUTIONS.map((contribution, index) => (
          <a
            href={`${base}${contribution.link}`}
            class="card-interactive group animate-on-scroll"
            style={`animation-delay: ${index * 100}ms;`}
          >
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <span class="text-3xl">
                {contribution.icon === 'dataset' && '📊'}
                {contribution.icon === 'assessment' && '📈'}
                {contribution.icon === 'psychology' && '🧠'}
              </span>
            </div>
            <h3 class="text-xl font-semibold mb-3 group-hover:text-primary-600 transition-colors">
              {contribution.title}
            </h3>
            <p class="text-surface-500">
              {contribution.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Degradation Categories -->
  <section class="section bg-surface-100/50">
    <div class="container-custom">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Degradation Categories</h2>
        <p class="text-surface-500 max-w-2xl mx-auto">
          19 degradation types across 5 major categories, each calibrated at 3 severity degrees by expert radiologists.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {CATEGORIES.map((category, index) => (
          <a
            href={`${base}/examples`}
            class="card-interactive group animate-on-scroll"
            style={`animation-delay: ${index * 50}ms;`}
          >
            <div class="w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center transition-transform group-hover:scale-110"
                 style={`background: ${category.color}20; color: ${category.color};`}>
              <span class="text-2xl">
                {category.icon === 'blur_on' && '◐'}
                {category.icon === 'grain' && '▥'}
                {category.icon === 'warning' && '⚠'}
                {category.icon === 'brightness_6' && '◑'}
                {category.icon === 'motion_photos_on' && '⇄'}
              </span>
            </div>
            <h3 class="font-semibold text-center mb-1 group-hover:text-primary-600 transition-colors">
              {category.name}
            </h3>
            <p class="text-xs text-surface-400 text-center">
              {DEGRADATION_TYPES.filter(d => d.category === category.id).length} types
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-surface-100/50">
    <div class="container-custom">
      <div class="glass-strong rounded-3xl p-8 md:p-12 text-center animate-on-scroll">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">
          Ready to Explore?
        </h2>
        <p class="text-surface-500 max-w-xl mx-auto mb-8">
          Dive into our comprehensive medical image degradation benchmark.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${base}/results`} class="btn btn-primary">
            View Results
          </a>
          <a href={`${base}/examples`} class="btn btn-secondary">
            View Examples
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  table {
    border-collapse: separate;
    border-spacing: 0;
  }
</style>
